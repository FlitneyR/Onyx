{
	"version": "2.0.0",
	"tasks": [
		// cleanup commands
		{
			"label": "Clean",
			"command": "rm",
			"args": [ "-rf", "build" ],
			"options": { "cwd": "${workspaceFolder}" },
			"problemMatcher": []
		},
		// setup commands
		{
			"label": "Make build directories",
			"command": "mkdir",
			"args": [ "-p", "build/debug", "build/release", "build/profile" ],
			"options": { "cwd": "${workspaceFolder}" },
			"problemMatcher": []
		},
		// configure commands
		{
			"label": "Configure Debug",
			"command": "cmake",
			"args": [ "../.." ],
			"options": { "cwd": "${workspaceFolder}/build/debug" },
			"dependsOn": [ "Make build directories" ],
			"problemMatcher": []
		},
		{
			"label": "Configure Release",
			"command": "cmake",
			"args": [ "../.." ],
			"options": { "cwd": "${workspaceFolder}/build/release" },
			"dependsOn": [ "Make build directories" ],
			"problemMatcher": []
		},
		{
			"label": "Configure Profile",
			"command": "cmake",
			"args": [ "../.." ],
			"options": { "cwd": "${workspaceFolder}/build/profile" },
			"dependsOn": [ "Make build directories" ],
			"problemMatcher": []
		},
		// build commands
		{
			"label": "Build Debug",
			"command": "cmake",
			"args": [ "--build", ".", "--config", "Debug", "--parallel" ],
			"options": { "cwd": "${workspaceFolder}/build/debug" },
			"dependsOn": [ "Configure Debug", "Make build directories" ],
			"problemMatcher": []
		},
		{
			"label": "Build Release",
			"command": "cmake",
			"args": [ "--build", ".", "--config", "Release", "--parallel" ],
			"options": { "cwd": "${workspaceFolder}/build/release" },
			"dependsOn": [ "Configure Release", "Make build directories" ],
			"problemMatcher": []
		},
		{
			"label": "Build Profile",
			"command": "cmake",
			"args": [ "--build", ".", "--config", "Profile", "--parallel" ],
			"options": { "cwd": "${workspaceFolder}/build/profile" },
			"dependsOn": [ "Configure Profile", "Make build directories" ],
			"problemMatcher": []
		},
		// tool commands
		{
			"label": "Launch Tracy",
			"command": "tracy",
			"isBackground": true,
			"args": [ "-a", "localhost" ],
			// some magic required to let tracy run in the background ... why isn't `"isBackground": true` enough?
			"problemMatcher": [
				{
					"pattern": {
						"regexp": ".",
						"file": 1,
						"location": 2,
						"message": 3
					},
					"background": {
						"activeOnStart": true,
						"beginsPattern": ".",
						"endsPattern": ".",
					}
				}
			]
		},
		// group commands
		{
			"label": "Profile Pre Launch",
			"dependsOn": [ "Build Profile", "Launch Tracy" ],
			"dependsOrder": "sequence",
			"problemMatcher": []
		},
	]
}