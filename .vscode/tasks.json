{
	"version": "2.0.0",
	"tasks": [
		// setup commands
		{
			"label": "Make build directories",
			"command": "mkdir",
			"args": [ "-p", "build/debug", "build/release", "build/profile" ],
			"options": { "cwd": "${workspaceFolder}" },
		},
		// configure commands
		{
			"label": "Configure Debug",
			"command": "cmake",
			"args": [ "../.." ],
			"options": { "cwd": "${workspaceFolder}/build/debug" },
			"dependsOn": [ "Make build directories" ],
		},
		{
			"label": "Configure Release",
			"command": "cmake",
			"args": [ "../.." ],
			"options": { "cwd": "${workspaceFolder}/build/release" },
			"dependsOn": [ "Make build directories" ],
		},
		{
			"label": "Configure Profile",
			"command": "cmake",
			"args": [ "../.." ],
			"options": { "cwd": "${workspaceFolder}/build/profile" },
			"dependsOn": [ "Make build directories" ],
		},
		// build commands
		{
			"label": "Build Asteroids_Game Debug",
			"command": "cmake",
			"args": [ "--build", ".", "--config", "Debug", "--", "Asteroids_Game" ],
			"options": { "cwd": "${workspaceFolder}/build/debug" },
			"dependsOn": [ "Configure Debug", "Make build directories" ],
		},
		{
			"label": "Build Asteroids_Game Release",
			"command": "cmake",
			"args": [ "--build", ".", "--config", "Release", "--", "Asteroids_Game" ],
			"options": { "cwd": "${workspaceFolder}/build/release" },
			"dependsOn": [ "Configure Release", "Make build directories" ],
		},
		{
			"label": "Build Asteroids_Game Profile",
			"command": "cmake",
			"args": [ "--build", ".", "--config", "Profile", "--", "Asteroids_Game" ],
			"options": { "cwd": "${workspaceFolder}/build/profile" },
			"dependsOn": [ "Configure Profile", "Make build directories" ],
		},
		// tool commands
		{
			"label": "Launch Tracy",
			"command": "tracy",
			"isBackground": true,
			"args": [ "-a", "localhost" ],
			// some magic required to let tracy run in the background ... why isn't `"isBackground": true` enough?
			"problemMatcher": [
				{
					"pattern": {
						"regexp": ".",
						"file": 1,
						"location": 2,
						"message": 3
					},
					"background": {
						"activeOnStart": true,
						"beginsPattern": ".",
						"endsPattern": ".",
					}
				}
			]
		},
		// group commands
		{
			"label": "Profile Asteroids_Game Pre Launch",
			"dependsOn": [ "Build Asteroids_Game Profile", "Launch Tracy" ],
			"dependsOrder": "sequence",
		},
	]
}