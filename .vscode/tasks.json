{
	"version": "2.0.0",
	"tasks": [
		// cleanup commands
		{
			"label": "Clean",
			"command": "rm",
			"args": [ "-rf", "build" ],
			"options": { "cwd": "${workspaceFolder}" },
			"problemMatcher": []
		},
		// setup commands
		{
			"label": "Make build directories",
			"command": "mkdir",
			"args": [ "-p", "build/debug", "build/release", "build/profile" ],
			"options": { "cwd": "${workspaceFolder}" },
			"problemMatcher": []
		},
		// configure commands
		{
			"label": "Configure Debug",
			"command": "cmake",
			"args": [ "../.." ],
			"options": { "cwd": "${workspaceFolder}/build/debug" },
			"dependsOn": [ "Make build directories" ],
			"problemMatcher": []
		},
		{
			"label": "Configure Release",
			"command": "cmake",
			"args": [ "../.." ],
			"options": { "cwd": "${workspaceFolder}/build/release" },
			"dependsOn": [ "Make build directories" ],
			"problemMatcher": []
		},
		{
			"label": "Configure Profile",
			"command": "cmake",
			"args": [ "../.." ],
			"options": { "cwd": "${workspaceFolder}/build/profile" },
			"dependsOn": [ "Make build directories" ],
			"problemMatcher": []
		},
		// build commands
			// Debug
			{
				"label": "Build Debug",
				"command": "cmake",
				"args": [ "--build", ".", "--config", "Debug" ],
				"options": { "cwd": "${workspaceFolder}/build/debug" },
				"dependsOn": [ "Configure Debug", "Make build directories" ],
				"problemMatcher": []
			},
			{
				"label": "Build Asteroids_Game Debug",
				"command": "cmake",
				"args": [ "--build", ".", "--config", "Debug", "--", "Asteroids_Game" ],
				"options": { "cwd": "${workspaceFolder}/build/debug" },
				"dependsOn": [ "Configure Debug", "Make build directories" ],
				"problemMatcher": []
			},
			{
				"label": "Build Asteroids_Editor Debug",
				"command": "cmake",
				"args": [ "--build", ".", "--config", "Debug", "--", "Asteroids_Editor" ],
				"options": { "cwd": "${workspaceFolder}/build/debug" },
				"dependsOn": [ "Configure Debug", "Make build directories" ],
				"problemMatcher": []
			},
			// Release
			{
				"label": "Build Release",
				"command": "cmake",
				"args": [ "--build", ".", "--config", "Release" ],
				"options": { "cwd": "${workspaceFolder}/build/release" },
				"dependsOn": [ "Configure Release", "Make build directories" ],
				"problemMatcher": []
			},
			{
				"label": "Build Asteroids_Game Release",
				"command": "cmake",
				"args": [ "--build", ".", "--config", "Release", "--", "Asteroids_Game" ],
				"options": { "cwd": "${workspaceFolder}/build/release" },
				"dependsOn": [ "Configure Release", "Make build directories" ],
				"problemMatcher": []
			},
			{
				"label": "Build Asteroids_Editor Release",
				"command": "cmake",
				"args": [ "--build", ".", "--config", "Release", "--", "Asteroids_Editor" ],
				"options": { "cwd": "${workspaceFolder}/build/release" },
				"dependsOn": [ "Configure Release", "Make build directories" ],
				"problemMatcher": []
			},
			// Profile
			{
				"label": "Build Profile",
				"command": "cmake",
				"args": [ "--build", ".", "--config", "Profile" ],
				"options": { "cwd": "${workspaceFolder}/build/profile" },
				"dependsOn": [ "Configure Profile", "Make build directories" ],
				"problemMatcher": []
			},
			{
				"label": "Build Asteroids_Game Profile",
				"command": "cmake",
				"args": [ "--build", ".", "--config", "Profile", "--", "Asteroids_Game" ],
				"options": { "cwd": "${workspaceFolder}/build/profile" },
				"dependsOn": [ "Configure Profile", "Make build directories" ],
				"problemMatcher": []
			},
			{
				"label": "Build Asteroids_Editor Profile",
				"command": "cmake",
				"args": [ "--build", ".", "--config", "Profile", "--", "Asteroids_Editor" ],
				"options": { "cwd": "${workspaceFolder}/build/profile" },
				"dependsOn": [ "Configure Profile", "Make build directories" ],
				"problemMatcher": []
			},
		// tool commands
		{
			"label": "Launch Tracy",
			"command": "tracy",
			"isBackground": true,
			"args": [ "-a", "localhost" ],
			// some magic required to let tracy run in the background ... why isn't `"isBackground": true` enough?
			"problemMatcher": [
				{
					"pattern": {
						"regexp": ".",
						"file": 1,
						"location": 2,
						"message": 3
					},
					"background": {
						"activeOnStart": true,
						"beginsPattern": ".",
						"endsPattern": ".",
					}
				}
			]
		},
		// group commands
		{
			"label": "Profile Asteroids_Game Pre Launch",
			"dependsOn": [ "Build Asteroids_Game Profile", "Launch Tracy" ],
			"dependsOrder": "sequence",
			"problemMatcher": []
		},
		{
			"label": "Profile Asteroids_Editor Pre Launch",
			"dependsOn": [ "Build Asteroids_Editor Profile", "Launch Tracy" ],
			"dependsOrder": "sequence",
			"problemMatcher": []
		},
	]
}