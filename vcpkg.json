{
  "name": "onyx",
  "version": "0.1.0",
  "dependencies": [
    "assimp",
    "glm",
    "glslang",
    {
      "name": "imgui",
      "features": [
        "docking-experimental",
        "sdl2-binding",
        "vulkan-binding"
      ]
    },
    {
      "name": "sdl2",
      "features": [
        "vulkan"
      ]
    },
    "tracy",
    "vk-bootstrap",
    "vulkan",
    "vulkan-memory-allocator",
    "vulkan-memory-allocator-hpp"
  ],
  "overrides": [ 
    {
      "name": "zlib",
      "version": "1.3.1"
    },
    {
      "name": "rapidjson",
      "version": "2025-02-26"
    },
    {
      "name": "vulkan-memory-allocator",
      "version": "3.1.0"
    },
    {
      "name": "vulkan-memory-allocator-hpp",
      "version": "3.1.0"
    }
  ]
}
